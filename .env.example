# Secret key for signing sessions.
JWT_SECRET=super_secret_key_change_me_in_prod

# Discord OAuth Configuration
# 1. Create an application at https://discord.com/developers/applications
# 2. Get your Client ID and Client Secret
# 3. Add the callback URL under "OAuth2 > General" in the Discord dashboard:
#    Format: <YOUR_APP_URL>/auth/callback 
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Required Community Server ID (Guild ID)
# Right-click your server icon in Discord and copy ID (requires Developer Mode enabled in Discord Settings > Advanced)
DISCORD_SERVER_ID=
